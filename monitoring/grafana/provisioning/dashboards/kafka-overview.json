{
  "annotations": { "list": [] },
  "editable": true,
  "schemaVersion": 39,
  "title": "Kafka — Vue d'ensemble",
  "tags": ["kafka", "lab"],
  "time": { "from": "now-30m", "to": "now" },
  "refresh": "10s",
  "templating": { "list": [] },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "ID du Controller actif",
      "description": "ID du noeud KRaft qui joue le rôle de controller.",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "targets": [
        { "refId": "A", "expr": "kafka_server_metadataloader_currentcontrollerid" }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null }
          ] }
        },
        "overrides": []
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Partitions sous-répliquées",
      "description": "Doit valoir 0. Toute autre valeur indique un problème de réplication.",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "targets": [
        { "refId": "A", "expr": "kafka_server_replicamanager_underreplicatedpartitions" }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "red", "value": 1 }
          ] }
        },
        "overrides": []
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Brokers en ligne",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "targets": [
        { "refId": "A", "expr": "kafka_brokers" }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "red", "value": null },
            { "color": "green", "value": 1 }
          ] }
        },
        "overrides": []
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Lag total des consumers",
      "description": "Somme du retard de tous les consumer groups.",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "targets": [
        { "refId": "A", "expr": "sum(kafka_consumergroup_lag) or vector(0)" }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "orange", "value": 1000 },
            { "color": "red", "value": 100000 }
          ] }
        },
        "overrides": []
      }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Partitions totales",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 4 },
      "targets": [
        { "refId": "A", "expr": "kafka_server_replicamanager_partitioncount" }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null }
          ] }
        },
        "overrides": []
      }
    },
    {
      "id": 6,
      "type": "stat",
      "title": "Partitions leader",
      "description": "Nombre de partitions dont ce broker est le leader.",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 4 },
      "targets": [
        { "refId": "A", "expr": "kafka_server_replicamanager_leadercount" }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null }
          ] }
        },
        "overrides": []
      }
    },
    {
      "id": 7,
      "type": "stat",
      "title": "Etat du broker",
      "description": "3 = Running. Voir documentation Kafka pour les autres états.",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 4 },
      "targets": [
        { "refId": "A", "expr": "kafka_server_kafkaserver_brokerstate" }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "red", "value": null },
            { "color": "green", "value": 3 }
          ] }
        },
        "overrides": []
      }
    },
    {
      "id": 8,
      "type": "stat",
      "title": "Charge réseau (idle %)",
      "description": "Pourcentage d'inactivité des threads réseau. Plus c'est haut, moins le broker est chargé.",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 4 },
      "targets": [
        { "refId": "A", "expr": "kafka_network_socketserver_networkprocessoravgidlepercent * 100", "legendFormat": "idle %" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "red", "value": null },
            { "color": "orange", "value": 30 },
            { "color": "green", "value": 70 }
          ] }
        },
        "overrides": []
      }
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Offset courant par topic",
      "description": "Nombre total de messages produits par topic (somme des offsets de toutes les partitions).",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        { "refId": "A", "expr": "sum by (topic) (kafka_topic_partition_current_offset)", "legendFormat": "{{topic}}" }
      ],
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] }
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Lag par consumer group",
      "description": "Retard de consommation par group. 0 = consumer à jour.",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        { "refId": "A", "expr": "sum by (consumergroup) (kafka_consumergroup_lag)", "legendFormat": "{{consumergroup}}" }
      ],
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] }
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Taille des logs par partition (topic events)",
      "description": "Taille en octets des segments de log sur disque.",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 16 },
      "targets": [
        { "refId": "A", "expr": "kafka_log_log_size_topic_events_partition_0", "legendFormat": "partition-0" },
        { "refId": "B", "expr": "kafka_log_log_size_topic_events_partition_1", "legendFormat": "partition-1" },
        { "refId": "C", "expr": "kafka_log_log_size_topic_events_partition_2", "legendFormat": "partition-2" }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes" }, "overrides": [] }
    }
  ]
}
